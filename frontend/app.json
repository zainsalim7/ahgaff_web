{
  "expo": {
    "name": "طالب الأحقاف",
    "slug": "ahgaff-student",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ahgaff-student",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ahgaff.student",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.ahgaff.student",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0d47a1"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0d47a1",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "طالب الأحقاف"
        }
      ]
    ]
  }
}
