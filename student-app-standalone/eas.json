{
  "cli": { "version": ">= 5.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "image": "ubuntu-22.04-jdk-17-ndk-r26b",
        "gradleCommand": ":app:assembleRelease"
      },
      "distribution": "internal",
      "node": "22.12.0",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://ahgaffweb-production-c582.up.railway.app"
      }
    },
    "production": {
      "android": { "buildType": "app-bundle" },
      "node": "22.12.0",
      "env": {
        "EXPO_PUBLIC_BACKEND_URL": "https://ahgaffweb-production-c582.up.railway.app"
      }
    }
  }
}
